{
    "name": "Streamlit Python Dev Environment",
    "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",
    "customizations": {
        "codespaces": {
            "openFiles": [
                "README.md",
                "streamlit_app.py"
            ]
        },
        "vscode": {
            "settings": {},
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },

    "forwardPorts": [
        8501
    ],

    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y build-essential cmake libgl1-mesa-glx libglib2.0-0 && pip3 install --user -r requirements.txt",
    "postAttachCommand": {
        "server": "streamlit run streamlit_app.py --server.enableCORS false --server.enableXsrfProtection false"
    },
    "portsAttributes": {
        "8501": {
            "label": "Application",
            "onAutoForward": "openPreview"
        }
    },
    "remoteUser": "vscode",
    "features": {}
}
